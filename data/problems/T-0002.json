    { "id": "substitute", "points": 2, "criterion": "数値を正しく代入する（2×0.8+5×0.6）", "keywords": ["2", "5"] },
    { "id": "result", "points": 2, "criterion": "最終値 ε=4.6% を単位つきで結論する", "keywords": ["4.6", "%"], "required": true },
