    "10.24",
    "12.8",
    "16.0",
    "38.4"
  ],
  "answer": "12.8",
  "solution": [
    "|Z|=√(8²+6²)=10Ω",
    "力率cosφ=R/|Z|=0.8",
    "相電圧V_p=400/√3、相電流I=V_p/|Z|",
    "P=3·I²·R=12.8kW",
    "別解 P=√3·V_l·I_l·cosφ でも一致"
  ],
