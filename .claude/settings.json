{
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck:web)",
      "Bash(npm run lint)",
      "Bash(npm run build:web)",
      "Bash(npm run validate:data)",
      "Bash(npm run verify)",
      "Bash(npm run audit:status)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git branch)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Bash(git clean -xdf*)",
      "Bash(*--no-verify*)",
      "Bash(rm -rf*)",
      "Bash(Remove-Item -Recurse -Force*)"
    ]
  }
}
