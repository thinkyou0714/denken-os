    "format": "biome check --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "ts-fsrs": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@vitest/coverage-v8": "^2.1.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
