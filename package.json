{
  "name": "denken-os",
  "version": "0.1.0",
  "private": true,
  "description": "電験二種 学習OS — 問題生成＆検証エンジンと運用ロジックの実装",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen": "tsx lib/engine/cli.ts",
