# DENKEN-OS 環境変数のひな型。コピーして .env を作る（.env はコミット禁止＝.gitignore 済）。
# 値は絶対にコミットしないこと（docs/automation/01 §10 / 横断原則4）。

# --- 問題生成エンジン（任意）---
# 未設定なら解説の言い回しは決定論スタブで生成（数値はどちらもコード算出で同一）。
ANTHROPIC_API_KEY=
# 解説リライトのモデル（任意, 既定 claude-haiku-4-5）
DENKEN_NARRATE_MODEL=

# --- 以下は実投稿・永続化フェーズで使用（認証取得は human-tasks.md）---
# X API v2（既定は下書きエクスポートのため未使用）
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Supabase（学習記録・弱点診断の永続化）
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Discord Bot（コミュニティ儀式）
DISCORD_BOT_TOKEN=
