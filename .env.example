# DENKEN-OS 環境変数のひな型。コピーして .env を作る（.env はコミット禁止＝.gitignore 済）。
# 値は絶対にコミットしないこと（docs/automation/01 §10 / 横断原則4）。
#
# 機密度分類:
#   [SECRET]  本番シークレット — 絶対にコミット禁止。環境変数 or CI Secrets で管理。
#   [CONFIG]  設定値 — 秘密ではないが環境依存。ローカル .env に書いてよい。
#   [OPTIONAL] 未設定でも動作する（スタブ/デフォルト値が使われる）。

# --- 問題生成エンジン（任意）---
# 未設定なら解説の言い回しは決定論スタブで生成（数値はどちらもコード算出で同一）。
# [SECRET][OPTIONAL] Anthropic API キー（Claude による解説生成に使用）
ANTHROPIC_API_KEY=
# [CONFIG][OPTIONAL] 解説リライトのモデル（任意, 既定 claude-haiku-4-5）
DENKEN_NARRATE_MODEL=
# [CONFIG][OPTIONAL] ナレーターモード（auto|stub|api、既定 auto）
#   auto: ANTHROPIC_API_KEY があれば api、なければ stub を使用
#   stub: LLM を呼ばず決定論スタブで解説を生成（CI/オフライン向け）
#   api:  常に Anthropic API を呼ぶ（ANTHROPIC_API_KEY 必須）
DENKEN_NARRATOR_MODE=

# --- 以下は実投稿・永続化フェーズで使用（認証取得は human-tasks.md）---
# [SECRET] X API v2（既定は下書きエクスポートのため未使用）
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# [SECRET] Supabase（学習記録・弱点診断の永続化）
# SUPABASE_URL は公開プロジェクト URL（https://<id>.supabase.co）— URLは非機密だが管理上ここに記載
SUPABASE_URL=
# SUPABASE_ANON_KEY は公開鍵だがプロジェクト識別子を含むため管理対象
SUPABASE_ANON_KEY=

# [SECRET] Discord Bot（コミュニティ儀式）
DISCORD_BOT_TOKEN=
