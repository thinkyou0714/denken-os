# 既定: テキストは自動判定し、チェックアウト時は LF に正規化（.editorconfig と整合）。
* text=auto eol=lf

# 言語統計・差分から除外したい生成物/同梱物（linguist）。
package-lock.json   linguist-generated=true
web/dist/**         linguist-generated=true
web/problems.json   linguist-generated=true
data/**             linguist-generated=true

# 手書きの検証済み標準問題（T-0001〜T-0003）は生成扱いを解除し、
# 人間が管理するソースデータとして linguist に認識させる（I-097）。
data/problems/T-0001.json  linguist-generated=false
data/problems/T-0002.json  linguist-generated=false
data/problems/T-0003.json  linguist-generated=false

# バイナリ扱い（差分を取らない）。
*.png  binary
*.jpg  binary
*.ico  binary
