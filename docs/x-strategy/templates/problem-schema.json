{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DENKEN-OS Problem",
  "description": "問題データの共通スキーマ。アプリの出題・検算・出典管理と『今日の一問』発信を一元化する。",
  "type": "object",
  "required": ["id", "subject", "topic", "difficulty", "statement", "answer", "solution", "validation", "source"],
  "$comment": "正解が選択肢のいずれかと一致する制約(multiple_choice)は、他フィールド参照のため標準JSON Schema draft-07では表現できない。03-quality-pipeline の投稿前チェックリストと生成ツール側で担保する。",
  "properties": {
    "id": { "type": "string", "description": "連番ID 例: T-0127" },
    "exam": { "type": "string", "enum": ["denken1_primary", "denken1_secondary", "denken2_primary", "denken2_secondary", "denken3"], "description": "対象試験区分（電験一種〜三種）" },
    "subject": { "type": "string", "enum": ["理論", "電力", "機械", "法規", "電力管理", "機械制御"] },
    "topic": { "type": "string", "description": "論点 例: 三相交流電力" },
    "format": { "type": "string", "enum": ["multiple_choice", "numeric", "descriptive"], "description": "記述(descriptive)は二次の主戦場" },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5, "description": "★1-5。実測正答率で補正する" },
    "params": {
      "type": "object",
      "description": "係数いじりの可変パラメータ。realistic_range 内で、答えが綺麗になる値のみ採用",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "realistic_range": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
        }
      }
    },
    "statement": { "type": "string", "description": "問題文" },
    "figure": { "type": "string", "description": "図/回路図のパスまたは説明(任意)" },
    "choices": { "type": "array", "items": { "type": "string" }, "description": "選択肢。誤りが『成立する引っ掛け』であること。multiple_choice では必須かつ2件以上" },
    "answer": { "type": "string", "description": "正解(綺麗な値・一意・有限であること)。multiple_choice では choices のいずれかと一致" },
    "solution": { "type": "array", "items": { "type": "string" }, "description": "解法ステップ(自作。引き写し禁止)" },
    "validation": {
      "type": "object",
      "required": ["solver_checked", "human_checked", "clean_answer", "physically_valid"],
      "description": "03-quality-pipeline の検算結果。全 true でないと validated/published にできない",
      "properties": {
        "solver_checked": { "type": "boolean", "description": "ソルバーで再現し答えが一致" },
        "human_checked": { "type": "boolean", "description": "人が手で解き直した" },
        "clean_answer": { "type": "boolean", "description": "答えが綺麗な値" },
        "physically_valid": { "type": "boolean", "description": "力率≦1 等、物理的に成立" },
        "supervisor_checked": { "type": "boolean", "description": "合格者監修(任意・重要論点は必須)" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "閾値未満は出題しない" }
      }
    },
    "source": {
      "type": "object",
      "required": ["type"],
      "description": "04-compliance に基づく出典。発信・アプリ双方で必ず表示。original 以外は citation 必須",
      "properties": {
        "type": { "type": "string", "enum": ["original", "past_exam_modified", "past_exam_quoted"], "description": "original=完全オリジナル(主軸推奨)" },
        "citation": { "type": "string", "description": "例: 令和○年度 第二種電気主任技術者試験 一次 機械（一部改変・改題）" }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "enum": ["past_exam_modified", "past_exam_quoted"] } } },
          "then": { "required": ["citation"] }
        }
      ]
    },
    "stats": {
      "type": "object",
      "description": "発信で集まる集合知。06 の誤答データ=堀 / 02 の難易度補正に使う",
      "properties": {
        "answered": { "type": "integer", "minimum": 0 },
        "correct_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "common_wrong_choice": { "type": "string" },
        "discrimination": { "type": "number", "minimum": -1, "maximum": 1, "description": "識別力 D（上位群-下位群の正答率差）" }
      }
    },
    "status": { "type": "string", "enum": ["draft", "validated", "published", "retracted"], "description": "validated/published は検証4項目が全 true のときのみ。誤り発覚時は retracted" },
    "tags": { "type": "array", "items": { "type": "string" }, "description": "横断検索・関連出題・弱点クラスタリング用タグ" },
    "learning_objectives": { "type": "array", "items": { "type": "string" }, "description": "この問題が測る到達目標（逆向き設計）" },
    "formulas": { "type": "array", "items": { "type": "string" }, "description": "使用する主要公式（暗記カード/逆引き用）" },
    "hints": { "type": "array", "items": { "type": "string" }, "description": "答えを見る前の段階的ヒント（足場かけ）" },
    "choice_explanations": {
      "type": "array",
      "description": "各選択肢の誤答解説。13-best-practices §18 = 最大の学習資産",
      "items": {
        "type": "object",
        "required": ["choice", "correct", "explanation"],
        "properties": {
          "choice": { "type": "string" },
          "correct": { "type": "boolean" },
          "explanation": { "type": "string" }
        }
      }
    },
    "related_topics": { "type": "array", "items": { "type": "string" }, "description": "関連論点（推奨出題/知識グラフ）" },
    "prerequisites": { "type": "array", "items": { "type": "string" }, "description": "前提となる論点" },
    "estimated_time_sec": { "type": "integer", "minimum": 1, "description": "想定解答時間（秒）。ペース配分練習に使用" },
    "cognitive_level": { "type": "string", "enum": ["remember", "understand", "apply", "analyze"], "description": "認知レベル（Bloom改訂版の下位4段, QTI/item-bankメタ標準）" },
    "numeric": {
      "type": "object",
      "description": "数値採点の許容誤差と単位（有効数字差・丸め差の吸収）",
      "required": ["tolerance"],
      "properties": {
        "tolerance": { "type": "number", "minimum": 0 },
        "unit": { "type": "string" }
      }
    },
    "exam_meta": {
      "type": "object",
      "description": "過去問の出典メタ（年度・回・問番号）",
      "properties": {
        "year": { "type": "integer" },
        "era": { "type": "string" },
        "session": { "type": "string" },
        "question_no": { "type": "string" }
      }
    },
    "references": {
      "type": "array",
      "description": "法令条文などの根拠参照（法規で特に重要）",
      "items": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string" },
          "article": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "grading_points": { "type": "array", "items": { "type": "string" }, "description": "descriptive(記述)の採点観点（自己採点用）" },
    "sub_questions": {
      "type": "array",
      "description": "B問題の小問（1問内の小問構成）",
      "items": {
        "type": "object",
        "required": ["statement", "answer"],
        "properties": {
          "statement": { "type": "string" },
          "choices": { "type": "array", "items": { "type": "string" } },
          "answer": { "type": "string" },
          "solution": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["format"],
        "properties": { "format": { "const": "multiple_choice" } }
      },
      "then": {
        "required": ["choices"],
        "properties": { "choices": { "minItems": 2 } }
      }
    },
    {
      "if": {
        "required": ["status"],
        "properties": { "status": { "enum": ["validated", "published"] } }
      },
      "then": {
        "required": ["validation"],
        "properties": {
          "validation": {
            "required": ["solver_checked", "human_checked", "clean_answer", "physically_valid"],
            "properties": {
              "solver_checked": { "const": true },
              "human_checked": { "const": true },
              "clean_answer": { "const": true },
              "physically_valid": { "const": true }
            }
          }
        }
      }
    }
  ]
}
